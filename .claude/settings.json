{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(which:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(ruff:*)",
      "Bash(tox:*)",
      "Bash(fakeroot -u tox:*)",
      "Bash(pre-commit run:*)",
      "Bash(python scripts/make.py:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git blame:*)",
      "Bash(git stash list:*)",
      "Bash(PAGER=cat gh:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(pip install:*)"
    ],
    "deny": [
      "Bash(git add -A:*)",
      "Bash(git add --all:*)",
      "Bash(git add .)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.ssh/**)",
      "Read(**/*_key)",
      "Read(**/*.pem)"
    ]
  }
}
